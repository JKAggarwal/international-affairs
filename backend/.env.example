# Copy this file to .env and fill in your values

# --- Database ---
# Local default is SQLite (no config needed). In production set this to your
# managed Postgres connection string, e.g. from Neon:
# DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# --- OpenAI (optional) ---
# When set, story comparisons are generated by an LLM instead of the heuristic.
# Falls back to the heuristic automatically on any error.
# OPENAI_API_KEY=sk-your-key-here
# OPENAI_MODEL=gpt-4o-mini

# --- CORS ---
# Comma-separated list of allowed frontend origins. In production set this to
# your real domain(s). Defaults to localhost for development if unset.
# ALLOWED_ORIGINS=https://internationalaffairs.org.uk,https://www.internationalaffairs.org.uk

# --- Scheduler / fetching ---
# Run the in-process 6-hourly scheduler. Set to "false" on hosts that sleep
# when idle (free tiers) and use an external cron to hit /api/fetch-news.
# ENABLE_SCHEDULER=true

# Whether to fetch news on startup: "auto" (only when the DB is empty),
# "true", or "false". Keep "auto"/"false" in production to avoid an
# expensive RSS+LLM run on every cold start.
# FETCH_ON_STARTUP=auto

# Secret required to trigger /api/fetch-news (via X-Fetch-Token header or
# ?token=). Set a long random value in production so the public can't run
# your LLM-billed pipeline. Generate one with: python -c "import secrets;print(secrets.token_urlsafe(32))"
# FETCH_TOKEN=

# --- Server ---
# PORT is provided by most hosts automatically; only needed locally.
# PORT=8000
